<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="650dp"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/line_0"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="596dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.58"
        app:srcCompat="@drawable/map_path_left_locked"/>

    <ImageView
        android:id="@+id/line_1"
        android:layout_width="105dp"
        android:layout_height="103dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.28"
        app:layout_constraintVertical_bias="0.894"
        app:srcCompat="@drawable/map_path_left_locked"/>

    <ImageView
        android:id="@+id/line_4"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.79"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/map_path_left_locked"/>

    <ImageView
        android:id="@+id/line_3"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.73"
        app:layout_constraintVertical_bias="0.32"
        app:srcCompat="@drawable/map_path_right_locked"/>

    <ImageView
        android:id="@+id/line_2"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.28"
        app:layout_constraintVertical_bias="0.61"
        app:srcCompat="@drawable/map_path_right_locked"/>

    <ImageView
        android:id="@+id/light_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.47"
        app:layout_constraintVertical_bias="1"
        app:srcCompat="@drawable/map_star_glow"/>

    <ImageView
        android:id="@+id/light_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.1"
        app:layout_constraintVertical_bias="0.748"
        app:srcCompat="@drawable/map_star_glow"/>

    <ImageView
        android:id="@+id/light_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintVertical_bias="0.459"
        app:srcCompat="@drawable/map_star_glow"/>

    <ImageView
        android:id="@+id/light_4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.93"
        app:layout_constraintVertical_bias="0.17"
        app:srcCompat="@drawable/map_star_glow"/>

    <ImageView
        android:id="@+id/star_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#F9D92F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.47"
        app:layout_constraintVertical_bias="1"
        app:srcCompat="@drawable/map_star_locked"/>

    <ImageView
        android:id="@+id/star_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.1"
        app:layout_constraintVertical_bias="0.748"
        app:srcCompat="@drawable/map_star_locked"/>

    <ImageView
        android:id="@+id/star_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintVertical_bias="0.459"
        app:srcCompat="@drawable/map_star_locked"/>

    <ImageView
        android:id="@+id/star_4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.93"
        app:layout_constraintVertical_bias="0.17"
        app:srcCompat="@drawable/map_star_locked"/>

    <TextView
        android:id="@+id/num_1"
        android:layout_width="30dp"
        android:layout_height="25dp"
        android:gravity="center"
        android:hint="00"
        android:textColor="#E7E8E9"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/star_1"
        app:layout_constraintStart_toStartOf="@id/star_1"
        app:layout_constraintTop_toTopOf="@id/star_1"/>

    <TextView
        android:id="@+id/num_2"
        android:layout_width="30dp"
        android:layout_height="25dp"
        android:gravity="center"
        android:hint="00"
        android:textColor="#E7E8E9"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/star_2"
        app:layout_constraintStart_toStartOf="@id/star_2"
        app:layout_constraintTop_toTopOf="@id/star_2"/>

    <TextView
        android:id="@+id/num_3"
        android:layout_width="30dp"
        android:layout_height="25dp"
        android:gravity="center"
        android:hint="00"
        android:textColor="#E7E8E9"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/star_3"
        app:layout_constraintStart_toStartOf="@id/star_3"
        app:layout_constraintTop_toTopOf="@id/star_3"/>

    <TextView
        android:id="@+id/num_4"
        android:layout_width="30dp"
        android:layout_height="25dp"
        android:gravity="center"
        android:hint="00"
        android:textColor="#E7E8E9"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/star_4"
        app:layout_constraintStart_toStartOf="@id/star_4"
        app:layout_constraintTop_toTopOf="@id/star_4"/>

</androidx.constraintlayout.widget.ConstraintLayout>
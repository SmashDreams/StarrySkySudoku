<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000">

    <LinearLayout
        android:id="@+id/win_body"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:background="@drawable/dialog_background"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textview50"
                android:layout_width="15dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/textview63"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:gravity="center|left"
                android:text="@string/win"
                android:textColor="#070F18"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/win_close"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/icon_close"/>

            <TextView
                android:id="@+id/textview55"
                android:layout_width="15dp"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textview66"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/win_star_off"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/star_empty"/>

            <TextView
                android:id="@+id/textview68"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
        </LinearLayout>

        <TextView
            android:id="@+id/win_next"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:background="@drawable/dialog_button_dark"
            android:gravity="center"
            android:text="@string/next"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textview72"
            android:layout_width="match_parent"
            android:layout_height="16dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/win_star_on"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="45dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/win_body"
        app:layout_constraintEnd_toEndOf="@id/win_body"
        app:layout_constraintStart_toStartOf="@id/win_body"
        app:layout_constraintTop_toTopOf="@id/win_body"
        app:srcCompat="@drawable/star_earned"/>
</androidx.constraintlayout.widget.ConstraintLayout>

<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 应用基础主题。 -->
    <style name="Base.Theme.StarrySkySudoku" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/system_bar_night_sky</item>
        <item name="android:navigationBarColor">@color/system_bar_night_sky</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.StarrySkySudoku" parent="Base.Theme.StarrySkySudoku" >
        <item name="android:windowContentTransitions">true</item><!--动画平滑切换-->
    </style>

    <style name="MyDialog" parent="android:Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item><!--背景透明-->
        <item name="android:windowNoTitle">true</item><!--去除标题-->
        <item name="android:windowFrame">@null</item><!--去除边框-->
    </style>
    <style name="SlideInFromBottomDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_show</item>
        <item name="android:windowExitAnimation">@anim/dialog_hide</item>
    </style>

    <style name="GuideNumberKey">
        <item name="android:layout_width">55dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:background">@drawable/number_pad_key_background</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#020A13</item>
        <item name="android:textSize">23sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>

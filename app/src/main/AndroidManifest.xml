<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 读写战绩只允许同签名应用执行。 -->
    <permission
        android:name="com.bird.starryskysudoku.permission.READ_RESULTS"
        android:protectionLevel="signature" />

    <permission
        android:name="com.bird.starryskysudoku.permission.WRITE_RESULTS"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.bird.starryskysudoku.permission.READ_RESULTS" />
    <uses-permission android:name="com.bird.starryskysudoku.permission.WRITE_RESULTS" />
    <uses-permission android:name="com.bird.starryskyteahouse.permission.READ_SESSION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <queries>
        <provider android:authorities="com.bird.starryskyteahouse.provider" />
    </queries>

    <application
        android:name=".StarrySkySudokuApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.StarrySkySudoku"
        tools:targetApi="31">
        <service
            android:name=".media.BgmMusicService"
            android:exported="false" />

        <service
            android:name=".timer.CountdownTimerService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Shows the active Sudoku level and remaining time during gameplay" />
        </service>

        <provider
            android:name=".data.provider.GameResultProvider"
            android:authorities="com.bird.starryskysudoku.provider"
            android:exported="true"
            android:grantUriPermissions="false"
            android:readPermission="com.bird.starryskysudoku.permission.READ_RESULTS"
            android:writePermission="com.bird.starryskysudoku.permission.WRITE_RESULTS" />

        <activity
            android:name=".ui.howtoplay.HowToPlayActivity"
            android:launchMode="singleTask"/>
        <activity android:name=".ui.play.PlayActivity" />
        <activity
            android:name=".ui.map.MapActivity" />
        <activity
            android:name=".ui.guide.GuideActivity" />
        <activity
            android:name=".ui.splash.AppEntryActivity"
            android:exported="true"
            android:theme="@style/Theme.StarrySkySudoku.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
